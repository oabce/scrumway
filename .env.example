# Copie este arquivo para .env e ajuste os valores antes de subir o sistema.

# ScrumWay application settings
AUTH_SECRET=alterar_para_um_segredo_forte_e_unico
ADMIN_PASSWORD=alterar_senha_admin_inicial

# MariaDB connection settings
MARIADB_HOST=127.0.0.1
MARIADB_PORT=3306
MARIADB_DATABASE=scrumway
MARIADB_USER=scrumway
MARIADB_PASSWORD=alterar_senha_do_mariadb

# SQLAlchemy database URL used by backend/app.py
DATABASE_URL=mysql+pymysql://scrumway:alterar_senha_do_mariadb@127.0.0.1:3306/scrumway
